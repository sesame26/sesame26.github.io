n=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-md-{{imageWidth}} image-wrapper\">\n                <img class=\"w-100\" src=\"@PROJECT_PATH@/assets/images/mbr-696x464.jpeg\" alt=\"Mobirise\">\n            </div>\n            <div class=\"col-12 col-md\">\n                <div class=\"text-wrapper text-center\">\n                    <h1 class=\"mbr-section-title mbr-fonts-style mb-3\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\">\n                        <b>\n</b><div><span style=\"font-size: 3rem;\"><b>The 4rd Workshop on SErverless Systems, Applications and MEthodologies (SESAME'26)&nbsp;</b></span></div><div><br></div><div><br></div></h1>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\">The workshop is co-located with <a href=\"https://2026.eurosys.org/\" class=\"text-primary\">EuroSys'26</a>&nbsp;and will be conducted in person (no remote participants) on April 27th, bringing the experts from academia and industry to facilitate research in serverless systems in the International Conference Centre in Edinburgh, Scotland, UK.<br></p>\n                    <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn mt-3\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-secondary\" href=\"index.html#content5-j\" data-app-placeholder=\"Type Text\">Call for Papers</a> <a class=\"btn btn-primary\" href=\"https://sesame2023.hotcrp.com/\" data-app-placeholder=\"Type Text\" target=\"_blank\">Submit NOW</a></div>\n                </div>\n            </div>\n      